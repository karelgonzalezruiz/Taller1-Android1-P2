<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/fondo"
        android:orientation="vertical"
        android:padding="16dp">

    <!-- Titulo de la pantalla -->
    <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="8dp"
            android:layout_marginBottom="20dp"
            android:text="@string/titulo_listar"
            android:textColor="@color/primario"
            android:textSize="26sp"
            android:textStyle="bold" />

    <!-- Tarjeta que contiene la tabla -->
    <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:background="@drawable/tarjeta_fondo"
            android:padding="8dp"
            android:importantForAccessibility="no">

        <TableLayout
                android:id="@+id/tablaPersonas"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:stretchColumns="*" />
    </ScrollView>

    <!-- Boton para volver -->
    <Button
            android:id="@+id/btnVolver"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="16dp"
            android:background="@drawable/boton_fondo"
            android:onClick="Regresar"
            android:text="@string/btn_volver"
            android:textColor="@color/texto_claro" />

</LinearLayout>